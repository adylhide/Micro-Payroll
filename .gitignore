# ===================================================================
# 1. CRITICAL SECRETS & CREDENTIALS (Never commit these!)
# ===================================================================
# Ignores all .env files in both client/ and server/ directories
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Private keys, certificates, or local credentials
*.pem
*.key
*.pfx
*.cert

# ===================================================================
# 2. DEPENDENCIES (Prevents committing massive external code folders)
# ===================================================================
node_modules/
/client/node_modules/
/server/node_modules/

# ===================================================================
# 3. BUILD & COMPILED OUTPUTS
# ===================================================================
# Production build folders
dist/
/client/dist/
build/
out/

# ===================================================================
# 4. SYSTEM & OS FILES (Prevents noisy commits from your computer)
# ===================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ===================================================================
# 5. LOGS & DIAGNOSTICS
# ===================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===================================================================
# 6. EDITOR/IDE SETTINGS (Optional but keeps workspace configurations local)
# ===================================================================
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj

client/src/supabaseClient.js